# HyperFin Server Environment Variables
# Copy to .env and fill in values

PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://localhost:5432/hyperfin

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# Plaid
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox

# Server URL (for Plaid webhooks)
SERVER_URL=https://api.hyperfin.app

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Anthropic (cloud chat tier — opt-in only, used by /v1/chat/stream)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# S3-compatible training-data export (hourly upload of telemetry JSONL files).
# Default target is Cloudflare R2 — the free tier covers HyperFin's scale
# indefinitely. Works unchanged with Backblaze B2, AWS S3, or DO Spaces by
# pointing S3_ENDPOINT at the provider's URL (or unsetting it for AWS S3).
# If any required value is unset the uploader no-ops with a warning.
S3_BUCKET=hyperfin-training-data
S3_ACCESS_KEY_ID=your-r2-access-key-id
S3_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2 endpoint — find in Cloudflare dashboard → R2 → bucket → Settings → S3 API
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# R2 ignores region (use "auto"); AWS/Spaces want the real region (e.g. us-east-1)
S3_REGION=auto
S3_PREFIX=prod/telemetry/

# Local JSONL directory (defaults to ./telemetry-data when unset)
TELEMETRY_DIR=./telemetry-data

# Bearer token for /v1/admin/telemetry/* download endpoints.
# Generate with: openssl rand -hex 32
ADMIN_BEARER_TOKEN=replace-with-long-random-hex
